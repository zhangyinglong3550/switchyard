{
  "name": "switchyard",
  "version": "1.0.0",
  "description": "Local multi-client LLM gateway and desktop control panel for Codex, Claude Code, Hermes and other OpenAI-compatible / Anthropic-compatible tools.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhangyinglong3550/switchyard.git"
  },
  "bugs": {
    "url": "https://github.com/zhangyinglong3550/switchyard/issues"
  },
  "homepage": "https://github.com/zhangyinglong3550/switchyard#readme",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "gateway": "node packages/core/bin/gateway.mjs start",
    "gateway:init": "node packages/core/bin/gateway.mjs init",
    "gateway:doctor": "node packages/core/bin/gateway.mjs doctor",
    "gateway:models": "node packages/core/bin/gateway.mjs models",
    "test": "node --test packages/core/test/*.mjs",
    "check": "node -e \"['packages/core/src/config.mjs','packages/core/src/router.mjs','packages/core/src/upstream.mjs','packages/core/src/utils.mjs','packages/core/src/server.mjs','packages/core/src/openai-adapter.mjs','packages/core/src/anthropic-adapter.mjs','packages/core/src/profile-writer.mjs','packages/core/src/history-unify.mjs','packages/core/src/keychain-store.mjs','packages/core/src/compat/index.mjs','packages/core/src/compat/registry.mjs','packages/core/src/compat/fixture-runner.mjs','packages/core/src/compat/patches/opencode-glm-no-tools.mjs','packages/core/bin/gateway.mjs','apps/desktop/src/main.mjs','apps/desktop/src/preload.cjs','apps/desktop/src/gateway-host.mjs','apps/desktop/src/config-store.mjs','apps/desktop/src/logs.mjs','apps/desktop/src/request-log-store.mjs','apps/desktop/src/agent-resources.mjs','apps/desktop/src/agent-plugins.mjs','apps/desktop/src/keychain-store.mjs','apps/desktop/src/diagnostics.mjs','apps/desktop/src/issue-bundle.mjs','apps/desktop/src/provider-health.mjs','apps/desktop/src/test-console.mjs','apps/desktop/renderer/renderer.js','apps/desktop/renderer/client-visibility-utils.mjs','apps/desktop/renderer/discovery-filter.mjs','apps/desktop/renderer/import-selection-utils.mjs','apps/desktop/renderer/model-form-utils.mjs'].forEach(p=>require('child_process').execSync('node --check '+p,{stdio:'inherit'}))\"",
    "desktop": "electron apps/desktop/src/main.mjs",
    "desktop:dev": "electron apps/desktop/src/main.mjs",
    "desktop:dmg": "electron-builder --mac dmg",
    "desktop:win": "electron-builder --win nsis zip --x64",
    "release:check": "node scripts/release-check.mjs",
    "import:ccswitch": "node scripts/import-ccswitch.mjs"
  },
  "devDependencies": {
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "com.zhangyinglong.switchyard",
    "productName": "Switchyard",
    "files": [
      "package.json",
      "apps/desktop/**/*",
      "packages/core/**/*",
      "config/**/*",
      "!**/*.map",
      "!**/test/**"
    ],
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "icon": "apps/desktop/assets/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "win": {
      "icon": "apps/desktop/assets/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "extraMetadata": {
      "main": "apps/desktop/src/main.mjs"
    }
  },
  "allowScripts": {
    "electron@33.4.11": true
  },
  "main": "apps/desktop/src/main.mjs",
  "author": {
    "name": "Switchyard Team"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "better-sqlite3": "^12.11.1",
    "undici": "^6.27.0"
  }
}
